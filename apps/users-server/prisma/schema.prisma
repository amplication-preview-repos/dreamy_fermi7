datasource db {
  provider = "mysql"
  url      = env("DB_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  createdAt               DateTime       @default(now())
  documentNumber          String         @unique
  documentType EnumUserDocumentType @,
  documents               Document?
  email                   String         @unique
  familyNameAr            String
  familyNameEn            String
  firstNameAr             String
  firstNameEn             String
  gender                  EnumUserGender
  id                      String         @id @default(cuid())
  isCompanyRepresentative Boolean
  isSpecialNeeds          Boolean
  memberships             Membership[]
  mobile                  String?        @unique
  password                String?
  phoneCountrycode String @defalt(+966)
  profilePhotoPublic      Boolean?
  profilePhotoUrl         Json?
  roles                   String
  secondNameAr            String
  secondNameEn            String
  sessionId               String?
  thirdNameAr             String?
  thirdNameEn             String?
  updatedAt               DateTime       @updatedAt
  username                String         @unique
}

model Club {
  category    String?
  ccode       String       @unique
  createdAt   DateTime     @default(now())
  id          String       @id @default(cuid())
  memberships Membership[]
  name        String       @unique
  updatedAt   DateTime     @updatedAt
}

model Membership {
  club            Club                      @relation(fields: [clubId], references: [id])
  clubId          String
  createdAt       DateTime                  @default(now())
  durationYears   String
  endDate         DateTime
  id              String                    @id @default(cuid())
  paidAmount      Decimal
  paymentProofUrl Document[]
  sourceType      EnumMembershipSourceType?
  startDate       DateTime
  status          String
  updatedAt       DateTime                  @updatedAt
  user            User                      @relation(fields: [userId], references: [id])
  userId          String
}

model Document {
  application   String?
  createdAt     DateTime    @default(now())
  createdBy     User?       @relation(fields: [ID], references: [id])
  ID            String?     @unique
  fileName      String?
  fileUrl       String?
  id            String      @id @default(cuid())
  memberships   Membership? @relation(fields: [membershipsId], references: [id])
  membershipsId String?
  objectId      String?
  requestId     String?
  requestType   String?
  requestubype  String?
  updatedAt     DateTime    @updatedAt
}

enum EnumUserDocumentType {
  ID
  RP
  PASSPORT
}

enum EnumUserGender {
  M
  F
}

enum EnumMembershipSourceType {
  NEW
  EXISTING_OFFSYSTEM
}
